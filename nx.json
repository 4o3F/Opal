{
  "$schema": "https://raw.githubusercontent.com/nrwl/nx/master/packages/nx/schemas/nx-schema.json",
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "sharedGlobals": ["{workspaceRoot}/deno.json"],
    "production": [
      "default",
      "!{projectRoot}/**/*.test.ts",
      "!{projectRoot}/**/*_test.ts",
      "!{projectRoot}/test/**/*"
    ]
  },
  "targetDefaults": {
    "check": {
      "inputs": ["production"],
      "cache": true
    },
    "lint": {
      "inputs": ["default"],
      "cache": true
    },
    "test": {
      "inputs": ["default"],
      "cache": true,
      "dependsOn": ["^check"]
    },
    "build": {
      "inputs": ["production"],
      "cache": true,
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false
    }
  },
  "defaultBase": "main",
  "useInferencePlugins": false,
  "nxCloudAccessToken": ""
}
